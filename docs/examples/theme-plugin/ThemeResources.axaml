<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 自定义颜色 -->
    <SolidColorBrush x:Key="MyPrimaryColor" Color="#FF6B6B"/>
    <SolidColorBrush x:Key="MySecondaryColor" Color="#4ECDC4"/>
    <SolidColorBrush x:Key="MyAccentColor" Color="#FFE66D"/>

    <!-- 自定义背景 -->
    <SolidColorBrush x:Key="MyBackground" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="MySurface" Color="#16213E"/>

    <!-- 自定义样式 -->
    <Style Selector="Button.mybutton">
        <Setter Property="Background" Value="{DynamicResource MyPrimaryColor}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="16,8"/>
    </Style>

</ResourceDictionary>
